<mxfile host="Claude">
  <diagram id="flow-instrument-input" name="楽器updateInput">
    <mxGraphModel dx="780" dy="1150" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="780" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="updateInput（楽器・受信処理）" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1"><mxGeometry x="240" y="30" width="280" height="44" as="geometry"/></mxCell>
        <mxCell id="d1" value="受信バッファに&lt;br&gt;パケットがある?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="275" y="104" width="210" height="84" as="geometry"/></mxCell>
        <mxCell id="p1" value="先頭 2 バイトのマジックナンバー 0x4F52 と&lt;br&gt;サイズ 20 バイトを検証（不正なら読み捨て）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="215" y="222" width="330" height="54" as="geometry"/></mxCell>
        <mxCell id="p2" value="時計サンプル s = timestampMs − millis() を&lt;br&gt;窓 2 s に追加し，推定オフセット θ̂ = max(s) を更新&lt;br&gt;（min フィルタ，式(6)）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="215" y="310" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="d2" value="|s − θ̂| &amp;gt; 1000 ms?&lt;br&gt;（マスタ時計の巻き戻り）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="270" y="410" width="220" height="88" as="geometry"/></mxCell>
        <mxCell id="p3" value="スナップ：θ̂ を即時追従させ&lt;br&gt;発音予約を破棄して再開" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="545" y="427" width="220" height="54" as="geometry"/></mxCell>
        <mxCell id="d3" value="パケット種別?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="285" y="532" width="190" height="80" as="geometry"/></mxCell>
        <mxCell id="p4" value="CTRL：テンポ・強弱・状態・モードを&lt;br&gt;SystemData へ書く" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="60" y="660" width="280" height="54" as="geometry"/></mxCell>
        <mxCell id="d4" value="BEAT：拍番号が&lt;br&gt;既受信と同じ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="425" y="646" width="210" height="84" as="geometry"/></mxCell>
        <mxCell id="p5" value="破棄（4 連送の重複受信）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;dashed=1;" vertex="1" parent="1"><mxGeometry x="560" y="770" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="p6" value="発音予約に登録&lt;br&gt;（beatNo・playAtMasterMs を保持）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="285" y="770" width="260" height="54" as="geometry"/></mxCell>
        <mxCell id="end" value="終了（ロジックフェーズへ）" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1"><mxGeometry x="270" y="880" width="220" height="44" as="geometry"/></mxCell>
