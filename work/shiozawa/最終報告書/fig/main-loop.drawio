        <mxCell id="wait" value="制御周期まで待機&lt;br&gt;（2 ms / 5 ms）" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;" vertex="1" parent="1"><mxGeometry x="140" y="440" width="220" height="44" as="geometry"/></mxCell>
        <mxCell id="f1" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="start" target="init"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="init" target="loopstart"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="loopstart" target="ph1"><mxGeometry relative="1" as="geometry"/></mxCell>
