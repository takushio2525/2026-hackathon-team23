<mxfile host="Claude">
  <diagram id="main-loop" name="メインループ">
    <mxGraphModel dx="540" dy="560" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="540" pageHeight="560" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
