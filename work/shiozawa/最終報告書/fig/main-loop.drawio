        <mxCell id="ph1" value="updateInput()&lt;br&gt;（UDP受信・IMU読取り）" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=12;" vertex="1" parent="1"><mxGeometry x="130" y="218" width="240" height="44" as="geometry"/></mxCell>
