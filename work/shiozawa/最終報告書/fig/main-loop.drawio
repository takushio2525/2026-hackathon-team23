<mxfile host="Claude">
  <diagram id="main-loop" name="メインループ">
    <mxGraphModel dx="700" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="電源投入" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1"><mxGeometry x="250" y="30" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="init" value="全モジュールの init()&lt;br&gt;（WiFi 起動・IMU キャリブレーション等）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="200" y="108" width="300" height="54" as="geometry"/></mxCell>
        <mxCell id="loopstart" value="loop 開始" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1"><mxGeometry x="250" y="196" width="200" height="44" as="geometry"/></mxCell>
        <mxCell id="ph1" value="【入力フェーズ】&lt;br&gt;全モジュールの updateInput() を順に実行&lt;br&gt;（UDP 受信・IMU 読取り → SystemData へ書く）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="274" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="ph2" value="【ロジックフェーズ】&lt;br&gt;applyPattern() を実行&lt;br&gt;（ノード固有の判断：拍検出／発火判定・楽譜進行）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="374" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="ph3" value="【出力フェーズ】&lt;br&gt;全モジュールの updateOutput() を順に実行&lt;br&gt;（UDP 送信・NOTE 送出・LED → SystemData を読む）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="185" y="474" width="330" height="66" as="geometry"/></mxCell>
        <mxCell id="wait" value="次の制御周期まで待つ&lt;br&gt;（楽器 2 ms／指揮者 5 ms）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="200" y="574" width="300" height="54" as="geometry"/></mxCell>
        <mxCell id="f1" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="start" target="init"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f2" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="init" target="loopstart"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f3" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="loopstart" target="ph1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f4" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ph1" target="ph2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f5" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ph2" target="ph3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="f6" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ph3" target="wait"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ret" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.3;exitX=0;exitY=0.5;entryX=0;entryY=0.5;curved=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="wait" target="loopstart"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="120" y="601"/><mxPoint x="120" y="218"/></Array></mxGeometry></mxCell>
        <mxCell id="note" value="全ノード共通の構造（モジュール間の通信は SystemData のみ）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="100" y="660" width="500" height="26" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
