<mxfile host="Claude">
  <diagram id="flow-conductor-beat" name="指揮者applyPattern">
    <mxGraphModel dx="820" dy="1240" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="1240" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="start" value="applyPattern（指揮者）" style="rounded=1;arcSize=50;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;" vertex="1" parent="1"><mxGeometry x="280" y="30" width="240" height="44" as="geometry"/></mxCell>
        <mxCell id="d0" value="キャリブレーション&lt;br&gt;完了?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="290" y="104" width="220" height="84" as="geometry"/></mxCell>
        <mxCell id="p0" value="静止計測を継続し g₀ を推定&lt;br&gt;（2 s で完了 → 拍待ち受けへ）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="119" width="240" height="54" as="geometry"/></mxCell>
        <mxCell id="p1" value="加速度を 1 次 IIR ローパスで平滑（式(1)）&lt;br&gt;動加速度ノルム d[n] を算出（式(2)）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="245" y="222" width="310" height="54" as="geometry"/></mxCell>
        <mxCell id="d1" value="Armed 状態?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="300" y="310" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="d2" value="d[n] &amp;gt; 1.20 g?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="560" y="310" width="200" height="80" as="geometry"/></mxCell>
        <mxCell id="p2" value="Armed へ遷移&lt;br&gt;（速度・経路長を 0 にリセット）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="540" y="430" width="240" height="54" as="geometry"/></mxCell>
        <mxCell id="p3" value="速度・移動経路長 L を積分（式(3)）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="260" y="430" width="280" height="44" as="geometry"/></mxCell>
        <mxCell id="d3" value="L ≥ 0.20 m かつ&lt;br&gt;不応期 350 ms 経過?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="285" y="508" width="230" height="92" as="geometry"/></mxCell>
        <mxCell id="p4" value="拍を発火：拍番号を進め&lt;br&gt;playAtMasterMs = 現在時刻 + 220 ms で&lt;br&gt;BEAT 送信要求を SystemData へ書く" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="245" y="640" width="310" height="66" as="geometry"/></mxCell>
        <mxCell id="p5" value="拍間隔からテンポを EMA 更新（式(4)）&lt;br&gt;動加速度ピークから強弱 velocity を算出&lt;br&gt;→ CTRL の内容を SystemData へ書く" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="245" y="740" width="310" height="66" as="geometry"/></mxCell>
        <mxCell id="d4" value="動きが収まった?&lt;br&gt;（d &amp;lt; 0.20 g または&lt;br&gt;ピークの 40% 未満が 40 ms）" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=11;" vertex="1" parent="1"><mxGeometry x="30" y="508" width="230" height="92" as="geometry"/></mxCell>
        <mxCell id="p6" value="Armed を解除（待機へ戻す）" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#333333;fontSize=12;" vertex="1" parent="1"><mxGeometry x="35" y="650" width="220" height="44" as="geometry"/></mxCell>
