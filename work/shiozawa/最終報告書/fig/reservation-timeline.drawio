<mxfile host="Claude">
  <diagram id="reservation-timeline" name="発音予約と時計同期">
    <mxGraphModel dx="1100" dy="480" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- レーンラベル -->
        <mxCell id="lane1" value="指揮者ノード&lt;br&gt;（マスタ時計）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="56" width="130" height="36" as="geometry"/></mxCell>
        <mxCell id="lane2" value="楽器ノード A" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="192" width="130" height="24" as="geometry"/></mxCell>
        <mxCell id="lane3" value="楽器ノード B" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="10" y="308" width="130" height="24" as="geometry"/></mxCell>
        <!-- レーン水平線 -->
        <mxCell id="hl1" style="endArrow=none;html=1;strokeColor=#AAAAAA;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="74" as="sourcePoint"/><mxPoint x="1040" y="74" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="hl2" style="endArrow=none;html=1;strokeColor=#AAAAAA;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="204" as="sourcePoint"/><mxPoint x="1040" y="204" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="hl3" style="endArrow=none;html=1;strokeColor=#AAAAAA;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="320" as="sourcePoint"/><mxPoint x="1040" y="320" as="targetPoint"/></mxGeometry></mxCell>
        <!-- 時間軸 -->
        <mxCell id="taxis" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="150" y="400" as="sourcePoint"/><mxPoint x="1040" y="400" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="taxisl" value="時間" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1044" y="390" width="40" height="20" as="geometry"/></mxCell>
        <!-- t0 縦点線 -->
        <mxCell id="vt0" style="endArrow=none;html=1;dashed=1;strokeColor=#666666;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="220" y="44" as="sourcePoint"/><mxPoint x="220" y="400" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="vt0l" value="t₀" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;" vertex="1" parent="1"><mxGeometry x="200" y="402" width="40" height="20" as="geometry"/></mxCell>
        <!-- 予約時刻 縦点線 -->
        <mxCell id="vplay" style="endArrow=none;html=1;dashed=1;strokeColor=#000000;strokeWidth=1.5;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="930" y="44" as="sourcePoint"/><mxPoint x="930" y="400" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="vplayl" value="t₀ + 220 ms" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="870" y="402" width="120" height="20" as="geometry"/></mxCell>
        <!-- 指揮者: 拍検出とBEAT送信 -->
        <mxCell id="beatdot" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="214" y="68" width="12" height="12" as="geometry"/></mxCell>
        <mxCell id="beatl" value="拍を検出" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="1"><mxGeometry x="186" y="40" width="80" height="20" as="geometry"/></mxCell>
        <mxCell id="send" value="BEAT送信（4連送）" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=11;" vertex="1" parent="1"><mxGeometry x="244" y="56" width="160" height="36" as="geometry"/></mxCell>
        <!-- 配送矢印 -->
        <mxCell id="d1" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="226" y="80" as="sourcePoint"/><mxPoint x="370" y="198" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d1l" value="配送遅延 小" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="248" y="148" width="80" height="18" as="geometry"/></mxCell>
        <mxCell id="d2" style="endArrow=block;endFill=1;html=1;strokeColor=#000000;strokeWidth=1;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="226" y="80" as="sourcePoint"/><mxPoint x="780" y="314" as="targetPoint"/></mxGeometry></mxCell>
        <mxCell id="d2l" value="配送遅延 大（バースト待ち）" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="470" y="224" width="170" height="18" as="geometry"/></mxCell>
        <!-- 楽器A -->
        <mxCell id="ra" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="364" y="198" width="12" height="12" as="geometry"/></mxCell>
        <mxCell id="ral" value="受信" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="348" y="176" width="44" height="18" as="geometry"/></mxCell>
        <mxCell id="wa" value="予約時刻まで待機（時計同期でローカル時刻へ換算）" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10;dashed=1;" vertex="1" parent="1"><mxGeometry x="390" y="186" width="524" height="36" as="geometry"/></mxCell>
        <mxCell id="fa" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="924" y="198" width="12" height="12" as="geometry"/></mxCell>
        <!-- 楽器B -->
        <mxCell id="rb" style="ellipse;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;strokeWidth=2;" vertex="1" parent="1"><mxGeometry x="774" y="314" width="12" height="12" as="geometry"/></mxCell>
        <mxCell id="rbl" value="受信" style="text;html=1;align=center;verticalAlign=middle;fontSize=10;" vertex="1" parent="1"><mxGeometry x="758" y="292" width="44" height="18" as="geometry"/></mxCell>
        <mxCell id="wb" value="待機" style="whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#000000;fontSize=10;dashed=1;" vertex="1" parent="1"><mxGeometry x="800" y="302" width="114" height="36" as="geometry"/></mxCell>
        <mxCell id="fb" style="ellipse;whiteSpace=wrap;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1"><mxGeometry x="924" y="314" width="12" height="12" as="geometry"/></mxCell>
        <!-- 発音ラベル -->
        <mxCell id="fire" value="同時発音" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="944" y="246" width="80" height="20" as="geometry"/></mxCell>
        <!-- 注記 -->
        <mxCell id="note" value="配送遅延がばらついても，予約時刻までにBEATが届けば発音時刻は揃う" style="text;html=1;align=center;verticalAlign=middle;fontSize=11;fontColor=#333333;" vertex="1" parent="1"><mxGeometry x="150" y="436" width="900" height="20" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
