<mxfile host="Claude">
  <diagram id="ema-module" name="EMA 3フェーズ構成">
    <mxGraphModel dx="1200" dy="480" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="480" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- 3フェーズ -->
        <mxCell id="ph1" value="&lt;b&gt;① 入力フェーズ&lt;/b&gt;&lt;br&gt;updateInput()&lt;br&gt;&lt;br&gt;OrcNetModule: UDP 受信&lt;br&gt;OrcReceiverModule:&lt;br&gt;パケット解釈・時計同期" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#6C8EBF;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="60" y="60" width="300" height="150" as="geometry"/></mxCell>
        <mxCell id="ph2" value="&lt;b&gt;② ロジックフェーズ&lt;/b&gt;&lt;br&gt;applyPattern()&lt;br&gt;&lt;br&gt;発音予約の発火判定&lt;br&gt;楽譜進行・NOTE 内容の決定&lt;br&gt;（ノード固有の処理）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="450" y="60" width="300" height="150" as="geometry"/></mxCell>
        <mxCell id="ph3" value="&lt;b&gt;③ 出力フェーズ&lt;/b&gt;&lt;br&gt;updateOutput()&lt;br&gt;&lt;br&gt;NoteSenderModule:&lt;br&gt;NOTE を USB シリアルへ送出&lt;br&gt;StatusLedModule: LED 表示" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8CECC;strokeColor=#B85450;fontSize=13;verticalAlign=top;spacingTop=8;" vertex="1" parent="1"><mxGeometry x="840" y="60" width="300" height="150" as="geometry"/></mxCell>
        <!-- フェーズ間矢印 -->
        <mxCell id="e12" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ph1" target="ph2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e23" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.5;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="ph2" target="ph3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- ループ矢印 -->
        <mxCell id="eloop" value="次周期へ（楽器ノードは 2 ms 周期）" style="endArrow=block;html=1;strokeColor=#333333;strokeWidth=1.5;fontSize=12;exitX=0.5;exitY=0;entryX=0.5;entryY=0;curved=0;edgeStyle=orthogonalEdgeStyle;" edge="1" parent="1" source="ph3" target="ph1"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="990" y="28"/><mxPoint x="210" y="28"/></Array></mxGeometry></mxCell>
        <!-- SystemData -->
        <mxCell id="sd" value="&lt;b&gt;共有構造体 SystemData&lt;/b&gt;（唯一のモジュール間インタフェース）&lt;br&gt;受信パケット・時計オフセット・発音予約・楽譜位置・NOTE 出力要求・LED 状態" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=13;" vertex="1" parent="1"><mxGeometry x="180" y="310" width="840" height="80" as="geometry"/></mxCell>
        <!-- 読み書き矢印 -->
        <mxCell id="rw1" value="書く" style="endArrow=block;startArrow=block;html=1;strokeColor=#9673A6;strokeWidth=1.3;fontSize=11;exitX=0.5;exitY=1;entryX=0.15;entryY=0;" edge="1" parent="1" source="ph1" target="sd"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rw2" value="読む・書く" style="endArrow=block;startArrow=block;html=1;strokeColor=#9673A6;strokeWidth=1.3;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="ph2" target="sd"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rw3" value="読む" style="endArrow=block;startArrow=block;html=1;strokeColor=#9673A6;strokeWidth=1.3;fontSize=11;exitX=0.5;exitY=1;entryX=0.85;entryY=0;" edge="1" parent="1" source="ph3" target="sd"><mxGeometry relative="1" as="geometry"/></mxCell>
        <!-- 注記 -->
        <mxCell id="note" value="モジュール同士の直接呼び出しは禁止（楽器ノードの例。指揮者ノードは入力＝ImuModule，出力＝OrcSenderModule に置き換わる）" style="text;html=1;align=center;verticalAlign=middle;fontSize=12;fontColor=#555555;" vertex="1" parent="1"><mxGeometry x="120" y="420" width="960" height="26" as="geometry"/></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
