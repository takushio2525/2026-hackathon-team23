<mxfile host="Claude">
  <diagram id="state-performer" name="楽器状態遷移">
    <mxGraphModel dx="800" dy="300" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="760" pageHeight="200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="idle" value="Idle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="30" y="80" width="160" height="58" as="geometry"/></mxCell>
        <mxCell id="wait" value="WaitStart" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="290" y="80" width="160" height="58" as="geometry"/></mxCell>
        <mxCell id="play" value="Playing" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=14;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="550" y="80" width="180" height="58" as="geometry"/></mxCell>
        <mxCell id="e1" value="WiFi 接続完了" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#5C8A4A;strokeWidth=1.5;fontSize=12;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="idle" target="wait"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" value="最初の BEAT 受信" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#5C8A4A;strokeWidth=1.5;fontSize=12;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="wait" target="play"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" value="BEAT 受信ごとに楽譜を進行（未着でも Playing を維持）" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;strokeColor=#5C8A4A;strokeWidth=1.5;fontSize=11;exitX=0.75;exitY=0;entryX=0.25;entryY=0;" edge="1" parent="1" source="play" target="play"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="685" y="30"/><mxPoint x="595" y="30"/></Array></mxGeometry></mxCell>
      </root>
    </mxGraphModel>
